# Telegram bot — create via @BotFather and paste the token here.
TELEGRAM_TOKEN=PASTE_BOT_TOKEN_FROM_BOTFATHER

# Owner chat-id — send your bot a message, then run
#   curl -s "https://api.telegram.org/bot$TELEGRAM_TOKEN/getUpdates" | python3 -m json.tool
# and copy the numeric `chat.id`. Single-user mode.
OWNER_CHAT_ID=YOUR_NUMERIC_CHAT_ID

# LLM endpoint (OpenAI-compatible) — point this at vLLM, llama.cpp server,
# Ollama's /v1 endpoint, or a hosted API.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=your-model-name

# Ollama (embeddings) — optional, currently unused.
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: sandbox container name (default: soma-sandbox)
# SOMA_CONTAINER=soma-sandbox

# Optional: repo root (default: directory containing core.py)
# SOMA_ROOT=/absolute/path/to/soma

# Optional: data directory for workspace/, events.jsonl and state files
# (default: $SOMA_ROOT/data/)
# SOMA_DATA=/absolute/path/to/data
