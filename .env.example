# Telegram-Bot — via @BotFather erstellen, Token einfügen
TELEGRAM_TOKEN=PASTE_BOT_TOKEN_FROM_BOTFATHER

# Owner-Chat-ID — schick deinem Bot eine Nachricht und nutze ein Skript wie
# `python -c "import os, requests; r=requests.get(f'https://api.telegram.org/bot{os.environ[\"TOKEN\"]}/getUpdates'); print(r.json())"`
# um deine eigene chat.id rauszufinden. Single-User-Modus.
OWNER_CHAT_ID=YOUR_NUMERIC_CHAT_ID

# vLLM-Endpoint (OpenAI-kompatibel) — passe an deinen Setup an
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=your-model-name

# Ollama (Embeddings) — optional, derzeit ungenutzt
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: Container-Name (Default: soma-sandbox)
# SOMA_CONTAINER=soma-sandbox

# Optional: Repo-Root (Default: das Verzeichnis von core.py)
# SOMA_ROOT=/absolute/path/to/soma

# Optional: Datenverzeichnis für workspace/ + events.jsonl + state
# (Default: $SOMA_ROOT/data/)
# SOMA_DATA=/absolute/path/to/data
